---
import '../styles/global.css';

const cookie = Astro.request.headers.get('cookie') || '';
const match = cookie.match(/user_id=([^;]+)/);
const userId = match ? decodeURIComponent(match[1]) : null;

if (!userId) {
  return Astro.redirect('/login');
}

// クエリ ?type=learning|mastered （不正値は learning 扱い）
const typeParam = Astro.url.searchParams.get('type');
const type = typeParam === 'mastered' ? 'mastered' : 'learning';
const title = type === 'mastered' ? '理解済み単語' : '学習単語';
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | AI英単語メモ</title>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans">

    <div class="max-w-2xl mx-auto px-5 py-10">

      <!-- ヘッダー -->
      <div class="mb-6 flex items-center gap-3">
        <a href="/" class="flex items-center gap-1.5 text-sm text-gray-400 hover:text-gray-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l14 0"/><path d="M5 12l6 6"/><path d="M5 12l6 -6"/></svg>
          戻る
        </a>
        <div class="flex items-center gap-2">
          <h1 class="text-lg font-medium text-gray-950">{title}</h1>
          <span id="countBadge" class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">0</span>
        </div>
      </div>

      <!-- 表示トグル -->
      <div class="flex items-center mb-4">
        <span class="text-xs text-gray-400">表示</span>
        <div class="ml-auto flex gap-1.5">
          <button id="toggleOriginal" class="flex items-center gap-1 text-xs border border-gray-200 rounded-lg px-2.5 py-1.5 text-gray-500 transition-colors" aria-pressed="false">
            <svg class="eye-on" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/><path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/></svg>
            <svg class="eye-off hidden" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10.585 10.587a2 2 0 0 0 2.829 2.828"/><path d="M16.681 16.673a8.717 8.717 0 0 1 -4.681 1.327c-3.6 0 -6.6 -2 -9 -6c1.272 -2.12 2.712 -3.678 4.32 -4.674m2.86 -1.146a9.055 9.055 0 0 1 1.82 -.18c3.6 0 6.6 2 9 6c-.666 1.11 -1.379 2.067 -2.138 2.87"/><path d="M3 3l18 18"/></svg>
            英語
          </button>
          <button id="toggleTranslation" class="flex items-center gap-1 text-xs border border-gray-200 rounded-lg px-2.5 py-1.5 text-gray-500 transition-colors" aria-pressed="false">
            <svg class="eye-on" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/><path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/></svg>
            <svg class="eye-off hidden" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10.585 10.587a2 2 0 0 0 2.829 2.828"/><path d="M16.681 16.673a8.717 8.717 0 0 1 -4.681 1.327c-3.6 0 -6.6 -2 -9 -6c1.272 -2.12 2.712 -3.678 4.32 -4.674m2.86 -1.146a9.055 9.055 0 0 1 1.82 -.18c3.6 0 6.6 2 9 6c-.666 1.11 -1.379 2.067 -2.138 2.87"/><path d="M3 3l18 18"/></svg>
            日本語
          </button>
        </div>
      </div>

      <ul id="vocabList" class="space-y-2 list-none p-0"></ul>

    </div>

    <script define:vars={{ TYPE: type }}>
      const vocabList      = document.getElementById('vocabList');
      const countBadge     = document.getElementById('countBadge');
      const toggleOriginal    = document.getElementById('toggleOriginal');
      const toggleTranslation = document.getElementById('toggleTranslation');

      let savedWords = [];
      let hideOriginal    = false;
      let hideTranslation = false;

      function escapeHtml(s) {
        return String(s ?? '').replace(/[&<>"']/g, c => (
          { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]
        ));
      }

      function maskedSpan(text, hidden, extraClass) {
        const safe = escapeHtml(text);
        if (!hidden) return `<span class="${extraClass}">${safe}</span>`;
        return `<span class="${extraClass} mask-hidden cursor-pointer select-none rounded bg-gray-100 text-transparent hover:bg-gray-200 transition-colors" data-reveal>${safe}</span>`;
      }

      function setToggle(btn, on) {
        btn.setAttribute('aria-pressed', String(on));
        btn.querySelector('.eye-on').classList.toggle('hidden', on);
        btn.querySelector('.eye-off').classList.toggle('hidden', !on);
        btn.classList.toggle('bg-gray-950', on);
        btn.classList.toggle('text-white', on);
        btn.classList.toggle('border-gray-950', on);
        btn.classList.toggle('text-gray-500', !on);
      }

      toggleOriginal.addEventListener('click', () => {
        hideOriginal = !hideOriginal;
        setToggle(toggleOriginal, hideOriginal);
        renderList();
      });
      toggleTranslation.addEventListener('click', () => {
        hideTranslation = !hideTranslation;
        setToggle(toggleTranslation, hideTranslation);
        renderList();
      });

      function wordItem(w) {
        const mastered = TYPE === 'mastered';
        const restoreBtn = mastered ? `
            <button
              onclick="setStatus(${w.id}, 'learning')"
              class="flex-shrink-0 h-7 px-2 flex items-center gap-1 rounded-lg border border-gray-100 text-xs text-gray-400 hover:bg-gray-50 hover:text-gray-600 transition-colors"
              aria-label="学習に戻す"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 14l-4 -4l4 -4"/><path d="M5 10h11a4 4 0 1 1 0 8h-1"/></svg>
              学習に戻す
            </button>` : '';
        return `
          <li class="bg-white border border-gray-100 rounded-xl px-4 py-3.5 shadow-sm flex gap-3 items-start">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap mb-1.5">
                ${maskedSpan(w.original, hideOriginal, 'text-base font-medium text-gray-950')}
                <span class="text-gray-300 text-xs">→</span>
                ${maskedSpan(w.translation, hideTranslation, 'text-sm text-gray-500')}
              </div>
              <p class="text-xs text-gray-400 italic truncate">${escapeHtml(w.example)}</p>
            </div>
            ${restoreBtn}
            <button
              onclick="deleteWord(${w.id})"
              class="flex-shrink-0 w-7 h-7 flex items-center justify-center rounded-lg border border-gray-100 text-gray-300 hover:bg-red-50 hover:border-red-200 hover:text-red-500 transition-colors"
              aria-label="削除"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M18 6l-12 12"/><path d="M6 6l12 12"/></svg>
            </button>
          </li>`;
      }

      function renderList() {
        const items = TYPE === 'mastered'
          ? savedWords.filter(w => w.status === 'mastered')
          : savedWords.filter(w => w.status !== 'mastered');

        countBadge.textContent = String(items.length);
        const emptyMsg = TYPE === 'mastered' ? '理解済みの単語はまだありません' : '学習中の単語はまだありません';

        vocabList.innerHTML = items.length
          ? items.map(w => wordItem(w)).join('')
          : `<li class="text-center py-12 text-sm text-gray-400">${emptyMsg}</li>`;
      }

      vocabList.addEventListener('click', (e) => {
        const el = e.target.closest('[data-reveal]');
        if (!el) return;
        el.classList.remove('mask-hidden', 'bg-gray-100', 'text-transparent', 'hover:bg-gray-200', 'cursor-pointer');
        el.removeAttribute('data-reveal');
      });

      async function loadWords() {
        try {
          const res = await fetch('/words');
          if (res.status === 401) { window.location.href = '/login'; return; }
          const data = await res.json();
          savedWords = data.words || [];
          renderList();
        } catch (e) {
          console.error(e);
        }
      }
      loadWords();

      window.setStatus = async function(id, status) {
        await fetch('/words', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, status }),
        });
        await loadWords();
      };

      window.deleteWord = async function(id) {
        await fetch('/words', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        await loadWords();
      };
    </script>
  </body>
</html>

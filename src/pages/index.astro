---
import '../styles/global.css';

const cookie = Astro.request.headers.get('cookie') || '';
const match = cookie.match(/user_id=([^;]+)/);
const userId = match ? decodeURIComponent(match[1]) : null;

if (!userId) {
  return Astro.redirect('/login');
}
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI英単語メモ</title>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans">

    <div class="max-w-2xl mx-auto px-5 py-10">

      <!-- ヘッダー -->
      <div class="mb-8 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-medium text-gray-950 flex items-center gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M19 4v16h-12a2 2 0 0 1 -2 -2v-12a2 2 0 0 1 2 -2h12z"/><path d="M19 16h-12a2 2 0 0 0 -2 2"/><path d="M9 8h6"/></svg>
            AI英単語メモ
          </h1>
          <p class="text-xs text-gray-400 mt-1">{userId}</p>
        </div>
        <button id="logoutBtn" class="text-xs text-gray-400 hover:text-gray-600 border border-gray-200 rounded-lg px-3 py-1.5 transition-colors">
          ログアウト
        </button>
      </div>

      <!-- クイズ開始 -->
      <a
        id="quizBtn"
        href="/quiz"
        class="mb-5 w-full flex items-center justify-center gap-2 h-12 bg-gray-950 hover:bg-gray-800 text-white text-sm font-medium rounded-xl transition-all duration-150 shadow-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"/><path d="M8 8m0 1a1 1 0 0 1 1 -1h6a1 1 0 0 1 1 1v0a1 1 0 0 1 -1 1h-6a1 1 0 0 1 -1 -1z"/><path d="M9 14l.01 0"/><path d="M13 14l2 0"/></svg>
        <span id="quizBtnLabel">クイズを始める</span>
      </a>

      <!-- 入力エリア -->
      <div class="bg-white border border-gray-100 rounded-xl p-4 mb-5 shadow-sm">
        <div class="flex gap-2">
          <input
            type="text"
            id="inputText"
            placeholder="例: ephemeral / 儚い"
            class="flex-1 h-10 px-3.5 text-base rounded-lg border border-gray-200 bg-gray-50 text-gray-900 placeholder:text-gray-400 focus:outline-none focus:border-gray-400 focus:ring-2 focus:ring-gray-200 transition-all"
          />
          <button
            id="generateBtn"
            class="h-10 px-5 bg-gray-950 hover:bg-gray-800 disabled:opacity-40 text-white text-sm font-medium rounded-lg transition-all duration-150 flex items-center gap-1.5 whitespace-nowrap"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 12a9 9 0 1 0 18 0a9 9 0 0 0 -18 0"/><path d="M12 9l0 .01"/><path d="M11 12l1 0l0 3l1 0"/></svg>
            <span id="btnLabel">生成</span>
          </button>
        </div>
      </div>

      <!-- エラーバー -->
      <div id="errorBar" class="hidden mb-4 flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg px-4 py-2.5" role="alert">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/><path d="M12 8l0 4"/><path d="M12 16l.01 0"/></svg>
        <span id="errorMsg"></span>
      </div>

      <!-- 生成結果 -->
      <div id="resultSection" class="hidden bg-white border border-gray-100 rounded-xl p-5 mb-6 shadow-sm">
        <p class="text-xs font-medium text-gray-400 uppercase tracking-widest mb-3">生成結果</p>
        <div class="flex items-baseline gap-2.5 flex-wrap mb-4">
          <span id="resOriginal" class="text-xl font-medium text-gray-950"></span>
          <span class="text-gray-300 text-sm">→</span>
          <span id="resTranslation" class="text-lg text-gray-500"></span>
        </div>
        <div class="border-t border-gray-100 pt-4 space-y-1">
          <p id="resExample" class="text-sm text-gray-700 italic leading-relaxed"></p>
          <p id="resMeaning" class="text-sm text-gray-400 leading-relaxed"></p>
        </div>
      </div>

      <!-- 表示トグル -->
      <div class="flex items-center mb-4">
          <span class="text-xs text-gray-400">表示</span>
          <div class="ml-auto flex gap-1.5">
            <button
              id="toggleOriginal"
              class="flex items-center gap-1 text-xs border border-gray-200 rounded-lg px-2.5 py-1.5 text-gray-500 transition-colors"
              aria-pressed="false"
            >
              <svg class="eye-on" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/><path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/></svg>
              <svg class="eye-off hidden" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10.585 10.587a2 2 0 0 0 2.829 2.828"/><path d="M16.681 16.673a8.717 8.717 0 0 1 -4.681 1.327c-3.6 0 -6.6 -2 -9 -6c1.272 -2.12 2.712 -3.678 4.32 -4.674m2.86 -1.146a9.055 9.055 0 0 1 1.82 -.18c3.6 0 6.6 2 9 6c-.666 1.11 -1.379 2.067 -2.138 2.87"/><path d="M3 3l18 18"/></svg>
              英語
            </button>
            <button
              id="toggleTranslation"
              class="flex items-center gap-1 text-xs border border-gray-200 rounded-lg px-2.5 py-1.5 text-gray-500 transition-colors"
              aria-pressed="false"
            >
              <svg class="eye-on" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/><path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/></svg>
              <svg class="eye-off hidden" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10.585 10.587a2 2 0 0 0 2.829 2.828"/><path d="M16.681 16.673a8.717 8.717 0 0 1 -4.681 1.327c-3.6 0 -6.6 -2 -9 -6c1.272 -2.12 2.712 -3.678 4.32 -4.674m2.86 -1.146a9.055 9.055 0 0 1 1.82 -.18c3.6 0 6.6 2 9 6c-.666 1.11 -1.379 2.067 -2.138 2.87"/><path d="M3 3l18 18"/></svg>
              日本語
            </button>
          </div>
      </div>

      <!-- 学習単語欄 -->
      <div class="mb-8">
        <div class="flex items-center gap-2 mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 19a9 9 0 0 1 9 0a9 9 0 0 1 9 0"/><path d="M3 6a9 9 0 0 1 9 0a9 9 0 0 1 9 0"/><path d="M3 6l0 13"/><path d="M12 6l0 13"/><path d="M21 6l0 13"/></svg>
          <span class="text-sm font-medium text-gray-500">学習単語</span>
          <span id="learningBadge" class="text-xs text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">0</span>
          <a id="learningMore" href="/list?type=learning" class="ml-auto hidden items-center gap-0.5 text-xs text-gray-400 hover:text-gray-600 transition-colors">
            さらに表示
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 6l6 6l-6 6"/></svg>
          </a>
        </div>
        <ul id="learningList" class="space-y-2 list-none p-0"></ul>
      </div>

      <!-- 理解済み単語欄 -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-500" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l5 5l10 -10"/></svg>
          <span class="text-sm font-medium text-gray-500">理解済み単語</span>
          <span id="masteredBadge" class="text-xs text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-full">0</span>
          <a id="masteredMore" href="/list?type=mastered" class="ml-auto hidden items-center gap-0.5 text-xs text-gray-400 hover:text-gray-600 transition-colors">
            さらに表示
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 6l6 6l-6 6"/></svg>
          </a>
        </div>
        <ul id="masteredList" class="space-y-2 list-none p-0"></ul>
      </div>

    </div>

    <script>
      const inputText      = document.getElementById('inputText');
      const generateBtn    = document.getElementById('generateBtn');
      const btnLabel       = document.getElementById('btnLabel');
      const errorBar       = document.getElementById('errorBar');
      const errorMsg       = document.getElementById('errorMsg');
      const resultSection  = document.getElementById('resultSection');
      const resOriginal    = document.getElementById('resOriginal');
      const resTranslation = document.getElementById('resTranslation');
      const resExample     = document.getElementById('resExample');
      const resMeaning     = document.getElementById('resMeaning');
      const learningList   = document.getElementById('learningList');
      const masteredList   = document.getElementById('masteredList');
      const learningBadge  = document.getElementById('learningBadge');
      const masteredBadge  = document.getElementById('masteredBadge');
      const learningMore   = document.getElementById('learningMore');
      const masteredMore   = document.getElementById('masteredMore');
      const PREVIEW_LIMIT  = 3; // トップに表示する最大件数
      const quizBtn        = document.getElementById('quizBtn');
      const quizBtnLabel   = document.getElementById('quizBtnLabel');
      const logoutBtn      = document.getElementById('logoutBtn');
      const toggleOriginal    = document.getElementById('toggleOriginal');
      const toggleTranslation = document.getElementById('toggleTranslation');

      let savedWords = [];
      let hideOriginal    = false; // 英語を隠す
      let hideTranslation = false; // 日本語を隠す

      function escapeHtml(s) {
        return String(s ?? '').replace(/[&<>"']/g, c => (
          { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]
        ));
      }

      function maskedSpan(text, hidden, extraClass) {
        const safe = escapeHtml(text);
        if (!hidden) return `<span class="${extraClass}">${safe}</span>`;
        return `<span class="${extraClass} mask-hidden cursor-pointer select-none rounded bg-gray-100 text-transparent hover:bg-gray-200 transition-colors" data-reveal>${safe}</span>`;
      }

      function setToggle(btn, on) {
        btn.setAttribute('aria-pressed', String(on));
        btn.querySelector('.eye-on').classList.toggle('hidden', on);
        btn.querySelector('.eye-off').classList.toggle('hidden', !on);
        btn.classList.toggle('bg-gray-950', on);
        btn.classList.toggle('text-white', on);
        btn.classList.toggle('border-gray-950', on);
        btn.classList.toggle('text-gray-500', !on);
      }

      toggleOriginal.addEventListener('click', () => {
        hideOriginal = !hideOriginal;
        setToggle(toggleOriginal, hideOriginal);
        renderList();
      });
      toggleTranslation.addEventListener('click', () => {
        hideTranslation = !hideTranslation;
        setToggle(toggleTranslation, hideTranslation);
        renderList();
      });

      async function loadWords() {
        try {
          const res = await fetch('/words');
          if (res.status === 401) { window.location.href = '/login'; return; }
          const data = await res.json();
          savedWords = data.words || [];
          renderList();
        } catch (e) {
          console.error(e);
        }
      }
      loadWords();

      logoutBtn.addEventListener('click', async () => {
        await fetch('/auth', { method: 'DELETE' });
        window.location.href = '/login';
      });

      inputText.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') generateBtn.click();
      });

      generateBtn.addEventListener('click', async () => {
        const text = inputText.value.trim();
        if (!text) return;

        generateBtn.disabled = true;
        btnLabel.textContent = '生成中...';
        errorBar.classList.add('hidden');
        resultSection.classList.add('hidden');

        try {
          const res = await fetch('/api', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ text }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || '通信エラーが発生しました');

          resOriginal.textContent    = data.original;
          resTranslation.textContent = data.translation;
          resExample.textContent     = data.example;
          resMeaning.textContent     = data.meaning;
          resultSection.classList.remove('hidden');

          await fetch('/words', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });

          await loadWords();
          inputText.value = '';

        } catch (err) {
          errorMsg.textContent = err instanceof Error ? err.message : '不明なエラー';
          errorBar.classList.remove('hidden');
        } finally {
          generateBtn.disabled = false;
          btnLabel.textContent = '生成';
        }
      });

      function wordItem(w, mastered) {
        // mastered のときは「学習に戻す」、learning のときは無し。両方に削除ボタン。
        const restoreBtn = mastered ? `
            <button
              onclick="setStatus(${w.id}, 'learning')"
              class="flex-shrink-0 h-7 px-2 flex items-center gap-1 rounded-lg border border-gray-100 text-xs text-gray-400 hover:bg-gray-50 hover:text-gray-600 transition-colors"
              aria-label="学習に戻す"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 14l-4 -4l4 -4"/><path d="M5 10h11a4 4 0 1 1 0 8h-1"/></svg>
              学習に戻す
            </button>` : '';
        return `
          <li class="bg-white border border-gray-100 rounded-xl px-4 py-3.5 shadow-sm flex gap-3 items-start">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap mb-1.5">
                ${maskedSpan(w.original, hideOriginal, 'text-base font-medium text-gray-950')}
                <span class="text-gray-300 text-xs">→</span>
                ${maskedSpan(w.translation, hideTranslation, 'text-sm text-gray-500')}
              </div>
              <p class="text-xs text-gray-400 italic truncate">${escapeHtml(w.example)}</p>
            </div>
            ${restoreBtn}
            <button
              onclick="deleteWord(${w.id})"
              class="flex-shrink-0 w-7 h-7 flex items-center justify-center rounded-lg border border-gray-100 text-gray-300 hover:bg-red-50 hover:border-red-200 hover:text-red-500 transition-colors"
              aria-label="削除"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M18 6l-12 12"/><path d="M6 6l12 12"/></svg>
            </button>
          </li>`;
      }

      function renderList() {
        const learning = savedWords.filter(w => w.status !== 'mastered');
        const mastered = savedWords.filter(w => w.status === 'mastered');

        learningBadge.textContent = String(learning.length);
        masteredBadge.textContent = String(mastered.length);

        // トップでは各3件まで表示
        learningList.innerHTML = learning.length
          ? learning.slice(0, PREVIEW_LIMIT).map(w => wordItem(w, false)).join('')
          : `<li class="text-center py-8 text-sm text-gray-400">学習中の単語はまだありません</li>`;

        masteredList.innerHTML = mastered.length
          ? mastered.slice(0, PREVIEW_LIMIT).map(w => wordItem(w, true)).join('')
          : `<li class="text-center py-8 text-sm text-gray-400">理解済みの単語はまだありません</li>`;

        // 3件を超えるときだけ「さらに表示」を出す（flex で表示）
        learningMore.classList.toggle('flex', learning.length > PREVIEW_LIMIT);
        learningMore.classList.toggle('hidden', learning.length <= PREVIEW_LIMIT);
        masteredMore.classList.toggle('flex', mastered.length > PREVIEW_LIMIT);
        masteredMore.classList.toggle('hidden', mastered.length <= PREVIEW_LIMIT);

        // 学習単語が0ならクイズ開始を無効化
        const canQuiz = learning.length > 0;
        quizBtn.classList.toggle('pointer-events-none', !canQuiz);
        quizBtn.classList.toggle('opacity-40', !canQuiz);
        quizBtnLabel.textContent = canQuiz ? 'クイズを始める' : '学習単語がありません';
      }

      // 隠れた語をタップで個別に表示
      function attachReveal(listEl) {
        listEl.addEventListener('click', (e) => {
          const el = e.target.closest('[data-reveal]');
          if (!el) return;
          el.classList.remove('mask-hidden', 'bg-gray-100', 'text-transparent', 'hover:bg-gray-200', 'cursor-pointer');
          el.removeAttribute('data-reveal');
        });
      }
      attachReveal(learningList);
      attachReveal(masteredList);

      window.setStatus = async function(id, status) {
        await fetch('/words', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, status }),
        });
        await loadWords();
      };

      window.deleteWord = async function(id) {
        await fetch('/words', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        await loadWords();
      };
    </script>
  </body>
</html>